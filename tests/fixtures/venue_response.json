    {
      "attribution": null,
      "body": "What’s better than a restaurant with a French dip on its menu? A restaurant with five French dips. —New York Magazine",
      "display": {
        "type": "text"
      },
      "icon": {
        "url": "https://s3.amazonaws.com/resy.com/images/icons/quote.svg"
      },
